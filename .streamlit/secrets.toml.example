# =====================================================================
# 接続情報テンプレート
#   使い方:
#     1. このファイルを同じフォルダに secrets.toml という名前でコピー
#     2. 各値を自分のものに書き換える
#   ※ secrets.toml は .gitignore 済み（GitHubに上がりません）
#   ※ 本番(Streamlit Community Cloud)では、アプリ設定の Secrets 画面に
#      同じ内容を貼り付けます（ファイルは不要）
#
#   この [supabase] セクションが存在すると、自動的にSupabaseモードに
#   切り替わります。無ければローカルSQLiteで動きます。
# =====================================================================

# 会場スタッフ共通の合言葉（公開URLの野良アクセス対策）
# この [auth] があるとログイン画面が出る。無ければ（ローカル）そのまま開く。
[auth]
pin = "1234"                                 # 会場スタッフに共有する合言葉

[supabase]
url = "https://xxxxxxxxxxxx.supabase.co"   # Project URL
key = "eyJhbGciOi..."                        # anon public key

# Notion同期を使う場合のみ設定（無ければ同期機能は非表示・no-op）
[notion]
token       = "ntn_xxxxxxxxxxxx"             # インテグレーションのトークン
database_id = "xxxxxxxxxxxxxxxxxxxxxxxxxxxx" # 集約先データベースID

# AI機能（日報生成・メモ要約）を使う場合のみ設定 ※課金発生
[ai]
api_key = "sk-ant-xxxxxxxx"                  # Anthropic APIキー
